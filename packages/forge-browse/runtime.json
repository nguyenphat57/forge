{
  "name": "forge-browse",
  "kind": "runtime-tool",
  "host": "runtime",
  "description": "Optional browser runtime bundle for Forge with shared CLI and control-plane state",
  "state": {
    "scope": "runtime-tool-global",
    "dev_root": {
      "strategy": "bundle-parent-relative",
      "path_relative": "forge-browse-state"
    },
    "sessions_relative_path": "state/sessions.json",
    "events_relative_path": "state/events.jsonl",
    "artifacts_relative_dir": "artifacts"
  }
}
