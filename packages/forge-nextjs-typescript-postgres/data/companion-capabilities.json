{
  "id": "nextjs-typescript-postgres",
  "package": "forge-nextjs-typescript-postgres",
  "version": "1.6.1",
  "compatibility": {
  "forge_core_min": "1.6.1",
    "forge_core_max": "1.x"
  },
  "feature_rules": {
    "nextjs": {
      "prompt_keywords_any": [
        "next.js",
        "nextjs",
        "next js"
      ],
      "package_dependencies_any": [
        "next"
      ],
      "file_markers_any": [
        "next.config.js",
        "next.config.mjs",
        "next.config.ts",
        "next-env.d.ts",
        "app/layout.tsx",
        "app/page.tsx"
      ],
      "repo_signals_any": [
        "next",
        "next.config.ts",
        "next.config.js",
        "app/",
        "app/page.tsx"
      ]
    },
    "typescript": {
      "package_dependencies_any": [
        "typescript"
      ],
      "package_dev_dependencies_any": [
        "typescript"
      ],
      "file_markers_any": [
        "tsconfig.json"
      ],
      "repo_signals_any": [
        "tsconfig.json",
        ".ts",
        ".tsx"
      ]
    },
    "postgres": {
      "package_dependencies_any": [
        "@prisma/client",
        "drizzle-orm",
        "kysely",
        "pg",
        "postgres"
      ],
      "package_dev_dependencies_any": [
        "prisma",
        "drizzle-kit"
      ],
      "file_markers_any": [
        "prisma/schema.prisma",
        "drizzle.config.ts",
        ".env.example"
      ],
      "repo_signals_any": [
        "postgres",
        "prisma",
        "schema.prisma",
        "drizzle"
      ]
    },
    "auth": {
      "package_dependencies_any": [
        "bcryptjs",
        "zod"
      ],
      "file_markers_any": [
        "lib/auth/password.ts",
        "app/(auth)/login/page.tsx",
        "app/(auth)/signup/page.tsx"
      ],
      "repo_signals_any": [
        "auth",
        "login",
        "signup"
      ]
    },
    "billing": {
      "package_dependencies_any": [
        "stripe"
      ],
      "file_markers_any": [
        "lib/billing/stripe.ts",
        "app/(app)/billing/page.tsx",
        "app/api/webhooks/stripe/route.ts"
      ],
      "repo_signals_any": [
        "billing",
        "stripe",
        "webhook"
      ]
    },
    "observability": {
      "prompt_keywords_any": [
        "deploy observability",
        "observability",
        "sentry",
        "otel",
        "health check"
      ],
      "package_dependencies_any": [
        "@sentry/nextjs",
        "@opentelemetry/api"
      ],
      "file_markers_any": [
        "lib/observability.ts",
        "app/api/health/route.ts",
        "app/(app)/status/page.tsx"
      ],
      "repo_signals_any": [
        "sentry",
        "opentelemetry",
        "health",
        "status"
      ]
    }
  },
  "activation_any": [
    "nextjs"
  ],
  "quality_bands": {
    "strong": [
      "nextjs",
      "typescript",
      "postgres"
    ],
    "baseline": [
      "nextjs",
      "typescript"
    ]
  },
  "init_presets": [
    {
      "id": "minimal-saas",
      "label": "Minimal SaaS",
      "template_dir": "templates/minimal-saas",
      "example_dir": "examples/minimal-saas",
      "script": "scripts/scaffold_preset.py",
      "default_package_manager": "npm"
    },
    {
      "id": "auth-saas",
      "label": "Auth SaaS",
      "template_dir": "templates/auth-saas",
      "example_dir": "examples/auth-saas",
      "script": "scripts/scaffold_preset.py",
      "default_package_manager": "npm"
    },
    {
      "id": "billing-saas",
      "label": "Billing SaaS",
      "template_dir": "templates/billing-saas",
      "example_dir": "examples/billing-saas",
      "script": "scripts/scaffold_preset.py",
      "default_package_manager": "npm"
    },
    {
      "id": "deploy-observability",
      "label": "Deploy Observability",
      "template_dir": "templates/deploy-observability",
      "example_dir": "examples/deploy-observability",
      "script": "scripts/scaffold_preset.py",
      "default_package_manager": "npm"
    }
  ],
  "command_profiles": {
    "file": "data/command-profiles.json",
    "script": "scripts/resolve_commands.py"
  },
  "verification_packs": {
    "file": "data/verification-packs.json",
    "script": "scripts/resolve_commands.py"
  },
  "doctor_checks": {
    "script": "scripts/enrich_doctor.py"
  },
  "map_enrichers": {
    "script": "scripts/enrich_map_codebase.py"
  },
  "help_next_hints": [
    "Start from app router boundaries and schema ownership before wide edits.",
    "Re-run lint, typecheck, test, and build before claiming a Next.js slice is production-ready."
  ],
  "template_catalog": [
    {
      "id": "minimal-saas",
      "path": "templates/minimal-saas",
      "summary": "Minimal App Router preset with Prisma-oriented Postgres shape."
    },
    {
      "id": "auth-saas",
      "path": "templates/auth-saas",
      "summary": "App Router preset with signup, login, session, and Prisma-backed auth tables."
    },
    {
      "id": "billing-saas",
      "path": "templates/billing-saas",
      "summary": "App Router preset with auth, Stripe billing surfaces, and subscription schema placeholders."
    },
    {
      "id": "deploy-observability",
      "path": "templates/deploy-observability",
      "summary": "App Router preset with health checks, release telemetry, and deployment readiness surfaces."
    }
  ],
  "example_catalog": [
    {
      "id": "minimal-saas",
      "path": "examples/minimal-saas",
      "summary": "Reference product shape for the companion baseline."
    },
    {
      "id": "auth-saas",
      "path": "examples/auth-saas",
      "summary": "Reference product shape for the auth-focused preset."
    },
    {
      "id": "billing-saas",
      "path": "examples/billing-saas",
      "summary": "Reference product shape for the billing-focused preset."
    },
    {
      "id": "deploy-observability",
      "path": "examples/deploy-observability",
      "summary": "Reference product shape for the deploy-observability preset."
    }
  ]
}
