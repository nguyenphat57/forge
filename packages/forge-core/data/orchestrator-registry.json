  "evidence_response_contract": {
    "required_patterns": [
      "I verified: [fresh evidence]. Correct because [reason]. Fixed: [change].",
      "I investigated: [evidence]. The current code stays because [reason].",
      "Clarification needed: [single precise question]."
    ],
    "required_fields": [
      "fresh evidence",
      "reason or disposition",
      "change or no-change stance"
    ],
    "banned_phrases": [
      "Good catch. I fixed it.",
      "Looks good now.",
      "Should be fixed.",
      "Probably fine.",
      "CI passed earlier."
    ]
  },
  "skill_usage_footer_contract": {
    "prefix": "Skills used:",
    "none_token": "none",
    "separator": ",",
    "require_on_every_response": false,
    "require_final_line": true,
    "require_unique_skills": true,
    "allow_none_token": false
  },
  "skill_selection_explanation_contract": {
    "heading": "Skill selection:",
    "none_prefix": "none -",
    "bullet_prefix": "- ",
    "require_on_every_response": false,
    "require_at_start": true,
    "require_reason_text": false,
    "require_match_with_footer": true,
    "allow_in_responses": false
  },
  "rationalization_patterns": [
    "Good catch. I fixed it.",
    "Should be fine now.",
    "CI passed earlier.",
    "I did not run the exact check, but the change is small.",
    "Test fail but it looks unrelated.",
    "Could not reproduce, so it is probably okay.",
    "Spec is basically clear, implementation can figure it out.",
    "Merge first, follow up later."
  ],
  "host_capabilities": {
    "contract_version": "v2",
    "supports_subagents": false,
    "supports_parallel_subagents": false,
    "default_tier": "controller-baseline",
    "tiers": {
      "controller-baseline": {
        "dispatch_mode": "controller-sequential",
        "supports_subagents": false,
        "supports_parallel_subagents": false,
        "dispatch_reasons": [
          "No independent review lanes required."
        ],
        "fallback_reasons": [
          "Subagents unavailable or unnecessary."
        ]
      },
      "review-lane-subagents": {
        "dispatch_mode": "independent-reviewers",
        "supports_subagents": true,
        "supports_parallel_subagents": false,
        "dispatch_reasons": [
          "Independent review lanes improve quality on medium and large work."
        ],
        "fallback_reasons": [
          "Reuse sequential lanes when host support is missing."
        ]
      },
      "parallel-workers": {
        "dispatch_mode": "parallel-workers",
        "supports_subagents": true,
        "supports_parallel_subagents": true,
        "dispatch_reasons": [
          "Parallel workers accelerate disjoint packet execution."
        ],
        "fallback_reasons": [
          "Degrade to independent reviewers or sequential lanes when host support is missing."
        ]
      }
    },
    "subagent_dispatch_skill": null
  }
}
