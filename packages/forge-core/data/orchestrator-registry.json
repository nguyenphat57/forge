  "verification_profiles": {
    "behavioral_with_harness": {
      "label": "Behavioral change + harness available",
      "steps": [
        "Capture a failing test or failing automated reproduction before editing behavior.",
        "Apply the minimal fix and rerun the focused test first.",
        "Run the nearest confidence command after the focused verification passes."
      ]
    },
    "behavioral_reproduction_first": {
      "label": "Behavioral change + no harness confirmed",
      "steps": [
        "Capture a manual reproduction, failing command, or smoke scenario before editing behavior.",
        "Apply the minimal fix and rerun the same scenario immediately.",
        "Record residual risk if no stronger automated verification exists."
      ]
    },
    "non_behavioral": {
      "label": "Non-behavioral or repo chore change",
      "steps": [
        "Define the verification command before editing.",
        "Use the narrowest valid check: diff, lint, typecheck, build, or smoke run.",
        "Do not claim done without fresh evidence from the chosen check."
      ]
    }
  },
