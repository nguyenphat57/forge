{
  "workflow_state_contract": {
    "stage_statuses": [
      "pending",
      "required",
      "active",
      "completed",
      "skipped",
      "blocked"
    ],
    "activation_reasons": [
      "workflow-directive",
      "behavioral-build",
      "visual-design",
      "debug-investigation",
      "session-restore",
      "claim-boundary"
    ],
    "skip_reasons": [
      "mechanical-change",
      "direction-already-locked",
      "artifact-already-sufficient",
      "low-risk-boundary"
    ],
    "contract_note": "Workflow-state keeps stage/status vocabulary only. Skill lookup lives in skill_catalog."
  },
  "skill_catalog": {
    "brainstorming": {
      "package": "forge-brainstorming",
      "canonical_path": "skills/brainstorming/SKILL.md",
      "trigger_summary": "Feature direction, behavior change, visual/design work, approach comparison, or multi-subsystem decomposition."
    },
    "writing-plans": {
      "package": "forge-writing-plans",
      "canonical_path": "skills/writing-plans/SKILL.md",
