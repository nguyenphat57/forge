    },
    "dispatching-parallel-agents": {
      "package": "forge-dispatching-parallel-agents",
      "canonical_path": "skills/dispatching-parallel-agents/SKILL.md",
      "trigger_summary": "Two or more independent tasks can run in parallel with disjoint write scopes."
    },
    "subagent-driven-development": {
      "package": "forge-subagent-driven-development",
      "canonical_path": "skills/subagent-driven-development/SKILL.md",
      "trigger_summary": "Written plan has independent task packets suitable for fresh worker and reviewer lanes."
    },
    "systematic-debugging": {
      "package": "forge-systematic-debugging",
      "canonical_path": "skills/systematic-debugging/SKILL.md",
      "trigger_summary": "Bug, regression, failing test, error, unexpected behavior, or prompt/agent behavior fix."
    },
    "requesting-code-review": {
      "package": "forge-requesting-code-review",
      "canonical_path": "skills/requesting-code-review/SKILL.md",
      "trigger_summary": "Work is complete enough to review before merge, PR, handoff, or a ready claim."
    },
    "receiving-code-review": {
      "package": "forge-receiving-code-review",
      "canonical_path": "skills/receiving-code-review/SKILL.md",
      "trigger_summary": "User, reviewer, CI, or another agent gives review feedback or requested changes."
    },
    "verification-before-completion": {
      "package": "forge-verification-before-completion",
      "canonical_path": "skills/verification-before-completion/SKILL.md",
      "trigger_summary": "About to say done, fixed, ready, tests pass, mergeable, deployable, or complete."
    },
    "finishing-a-development-branch": {
      "package": "forge-finishing-a-development-branch",
      "canonical_path": "skills/finishing-a-development-branch/SKILL.md",
      "trigger_summary": "Implementation and verification are complete enough to decide merge, PR, keep, or discard."
    },
    "writing-skills": {
      "package": "forge-writing-skills",
      "canonical_path": "skills/writing-skills/SKILL.md",
      "trigger_summary": "Creating, editing, splitting, absorbing, testing, hardening, or deploying Forge or host skills."
