  "evidence_response_contract": {
    "required_patterns": [
      "I verified: [fresh evidence]. Correct because [reason]. Fixed: [change].",
      "I investigated: [evidence]. The current code stays because [reason].",
      "Clarification needed: [single precise question]."
    ],
    "required_fields": [
      "fresh evidence",
      "reason or disposition",
      "change or no-change stance"
    ],
    "banned_phrases": [
      "Good catch. I fixed it.",
      "Looks good now.",
      "Should be fixed.",
      "Probably fine.",
      "CI passed earlier."
    ]
  },
  "rationalization_patterns": [
    "Good catch. I fixed it.",
    "Should be fine now.",
    "CI passed earlier.",
    "I did not run the exact check, but the change is small.",
    "Test fail but it looks unrelated.",
    "Could not reproduce, so it is probably okay.",
    "Spec is basically clear, implementation can figure it out.",
    "Merge first, follow up later."
  ],
  "host_capabilities": {
    "supports_subagents": false,
    "supports_parallel_subagents": false,
    "subagent_dispatch_skill": null,
    "delegation_contract": [
      "Fresh packet per delegated slice.",
      "Explicit ownership and write scope.",
      "Return changed files, verification, and residual risk."
    ]
  },
  "completion_states": {
    "in-progress": "Work is still active or lacks handoff evidence.",
    "ready-for-review": "Implementation evidence exists and the work is ready for review.",
    "ready-for-merge": "Scope is clear, evidence is strong, and no known blocker remains.",
    "blocked-by-residual-risk": "Known blocker or residual risk is too high to call done."
  }
}
