{
  "artifacts": [
    {
      "name": "source-repo-operator-surface",
      "bundle": "source-repo",
      "source": "docs/architecture/generated-host-artifacts/source-repo/operator-surface.md",
      "output": "docs/current/operator-surface.md",
      "target_kind": "repo-file"
    },
    {
      "name": "forge-codex-global-agents",
      "bundle": "forge-codex",
      "source": "docs/architecture/generated-host-artifacts/AGENTS.global.canonical.md",
      "output": "packages/forge-codex/overlay/AGENTS.global.md"
    },
    {
      "name": "forge-codex-bump-wrapper",
      "bundle": "forge-codex",
      "source": "docs/architecture/generated-host-artifacts/codex/workflows/operator/_shared_wrapper.md",
      "context": {
        "action": "bump"
      },
      "output": "packages/forge-codex/overlay/workflows/operator/bump.md"
    },
    {
      "name": "forge-codex-operator-surface-reference",
      "bundle": "forge-codex",
      "source": "docs/architecture/generated-host-artifacts/codex/docs/codex-operator-surface.md",
      "output": "packages/forge-codex/overlay/docs/codex-operator-surface.md"
    },
    {
      "name": "forge-antigravity-global-gemini",
      "bundle": "forge-antigravity",
      "source": "docs/architecture/generated-host-artifacts/GEMINI.global.canonical.md",
      "output": "packages/forge-antigravity/overlay/GEMINI.global.md"
    },
    {
      "name": "forge-antigravity-operator-surface-reference",
      "bundle": "forge-antigravity",
      "source": "docs/architecture/generated-host-artifacts/antigravity/docs/antigravity-operator-surface.md",
      "output": "packages/forge-antigravity/overlay/docs/antigravity-operator-surface.md"
    }
  ]
}
